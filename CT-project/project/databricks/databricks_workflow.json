{
  "name": "Project_Sentinel_Medallion_Pipeline",
  "tasks": [
    {
      "task_key": "Setup_and_Configs",
      "notebook_task": {
        "notebook_path": "/Shared/Project_Sentinel/notebooks/00_setup_and_configs",
        "base_parameters": {
          "environment": "dev",
          "base_path": "abfss://delta-forge@deltaforge.dfs.core.windows.net/",
          "database_name": "legacy_hms_db"
        }
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_E4ds_v5",
        "num_workers": 2,
        "spark_conf": {
          "spark.sql.adaptive.enabled": "true",
          "spark.databricks.delta.schema.autoMerge.enabled": "true"
        }
      }
    },
    {
      "task_key": "Bronze_Ingestion",
      "depends_on": [
        {
          "task_key": "Setup_and_Configs"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Shared/Project_Sentinel/notebooks/01_bronze_ingestion"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_E4ds_v5",
        "num_workers": 2
      }
    },
    {
      "task_key": "Silver_Cleansing",
      "depends_on": [
        {
          "task_key": "Bronze_Ingestion"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Shared/Project_Sentinel/notebooks/02_silver_cleansing"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_E4ds_v5",
        "num_workers": 2
      }
    },
    {
      "task_key": "Gold_KPI_Metrics",
      "depends_on": [
        {
          "task_key": "Silver_Cleansing"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Shared/Project_Sentinel/notebooks/03_gold_metrics"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_E4ds_v5",
        "num_workers": 2
      }
    }
  ],
  "format": "MULTI_TASK"
}
